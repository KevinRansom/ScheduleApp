<Application x:Class="ScheduleApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <!-- Shared brush -->
    <SolidColorBrush x:Key="SchedGridLineBrush" Color="#FFBFBFBF"/>

    <!-- NEW: Brushes used by TaskKindToBrushConverter and legend -->
    <SolidColorBrush x:Key="BrushCoverage" Color="#FFD8F1D8"/>
    <SolidColorBrush x:Key="BrushBreak"    Color="#FFFFE0B2"/>
    <SolidColorBrush x:Key="BrushLunch"    Color="#FFFFF59D"/>
    <SolidColorBrush x:Key="BrushIdle"     Color="#FFECEFF1"/>

    <!-- NEW: Monospace text style referenced in MainWindow -->
    <Style x:Key="MonospaceText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Global DataGrid defaults -->
    <Style TargetType="DataGrid">
      <Setter Property="GridLinesVisibility" Value="All"/>
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource SchedGridLineBrush}"/>
      <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource SchedGridLineBrush}"/>
      <Setter Property="BorderBrush"              Value="{StaticResource SchedGridLineBrush}"/>
      <Setter Property="BorderThickness"          Value="1"/>
      <Setter Property="SnapsToDevicePixels"      Value="True"/>
    </Style>

    <!-- IconButton style used by buttons in MainWindow.xaml -->
    <Style x:Key="IconButton" TargetType="Button">
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="MinWidth" Value="80"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0"/>
    </Style>
  </Application.Resources>
</Application>
